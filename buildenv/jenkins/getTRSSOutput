#!groovy

LABEL='ci.role.test&&hw.arch.x86&&sw.os.linux'

stage('Queue') {
	node("$LABEL") {
		cleanWs()
		getTRSSOutput()
	}
}

def getTRSSOutput() {
	stage('TRSS JSON') {
		def TIME_LIMIT = params.TIME_LIMIT ? params.TIME_LIMIT.toInteger() : 30
		timeout(time: TIME_LIMIT, unit: 'MINUTES') {
			try {
				copyArtifacts fingerprintArtifacts: true, projectName: "UploadFile", selector: lastSuccessful(), target: '.'
				sh "mv upload/TRSSOutput.tar.gz TRSSOutput.tar.gz"
				archiveArtifacts artifacts: 'TRSSOutput.tar.gz', fingerprint: true, allowEmptyArchive: false
			} finally {
				cleanWs()
			}
		}
	}
}

return this
